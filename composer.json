{
  "name": "clandevs/commerceflow",
  "description": "WooCommerce operations and automation platform.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Anisur Rahman",
      "homepage": "https://clandevs.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "composer/installers": "^2.3"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^10.5",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "wp-coding-standards/wpcs": "^3.1",
    "yoast/phpunit-polyfills": "^2.0",
    "php-stubs/woocommerce-stubs": "^10.9"
  },
  "autoload": {
    "psr-4": {
      "CommerceFlow\\": "src/"
    }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "optimize-autoloader": true
  },
  "scripts": {
    "phpcs": "phpcs --standard=./phpcs.xml --extensions=php -s",
    "phpcbf": "phpcbf --standard=./phpcs.xml --extensions=php",
    "phpstan": "phpstan analyse --configuration=./phpstan.neon --memory-limit=1G",
    "test": "phpunit -c ./phpunit.xml.dist",
    "test-coverage": "phpunit -c ./phpunit.xml.dist --coverage-html ./coverage"
  }
}
